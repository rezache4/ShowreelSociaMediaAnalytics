      "source": [
        "## 🧹 Cell 5 — Preprocessing utilities\n",
        "\n",
        "**Dual-path design** — the key fix from the architecture review:\n",
        "\n",
        "| Path | Emoji handling | Used for |\n",
        "|---|---|---|\n",
        "| `preprocess_for_bert` | Strip entirely | BERT sentiment, embeddings, clustering |\n",
        "| `preprocess_for_claude` | Convert to `[emoji:name]` | Claude sarcasm detection only |\n",
        "\n",
        "Keeping emoji as natural words (e.g. `applauso`) in the Claude path would cause `\"Che idea geniale 👏\"` to read as genuinely positive — the irony signal lives in the juxtaposition between text and the bracketed emoji marker."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cell-5",
      "metadata": {
        "id": "cell-5"
      },
      "outputs": [],
      "source": [
        "# ── Shared helpers ──────────────────────────────────────────────────────────\n",
        "\n",
        "def _base_clean(text: str) -> str:\n",
        "    \"\"\"Shared cleaning: NFC normalisation, URLs, mentions, hashtags, repeated chars.\"\"\"\n",
        "    if not isinstance(text, str) or not text.strip():\n",
        "        return \"\"\n",
        "    text = unicodedata.normalize(\"NFC\", text)\n",
        "    text = re.sub(r\"https?://\\S+|www\\.\\S+\", \" [URL] \", text)\n",
        "    text = re.sub(r\"@\\w+\", \" [UTENTE] \", text)\n",
        "    text = re.sub(r\"#(\\w+)\", r\"\\1\", text)\n",
        "    # Collapse repeated chars — preserves Italian double letters (max 2)\n",
        "    text = re.sub(r\"(.)\\1{2,}\", r\"\\1\\1\", text)\n",
        "    return re.sub(r\"\\s+\", \" \", text).strip()\n",
        "\n",
        "\n",
        "# ── Path A: BERT / embeddings — strip emoji cleanly ──────────────────────────\n",
        "\n",
        "def preprocess_for_bert(text: str) -> str:\n",
        "    \"\"\"Remove all emoji, then apply shared cleaning. Fed to BERT and the embedder.\"\"\"\n",
        "    if not isinstance(text, str) or not text.strip():\n",
        "        return \"\"\n",
        "    text = emoji.replace_emoji(text, replace=\"\")  # clean removal, no substitution\n",
        "    return _base_clean(text)\n",
        "\n",
        "\n",
        "# ── Path B: Claude — convert emoji to name] ───────────────────────────\n",
        "\n",
        "_EMOJI_RE = re.compile(\n",
        "    r\"[\\U0001F600-\\U0001F64F\\U0001F300-\\U0001F5FF\"\n",
        "    r\"\\U0001F680-\\U0001F6FF\\U0001F1E0-\\U0001F1FF\"\n",
        "    r\"\\U00002700-\\U000027BF\\U0001F900-\\U0001F9FF\"\n",
        "    r\"\\U00002600-\\U000026FF]+\",\n",
        "    flags=re.UNICODE,\n",
        ")\n",
        "\n",
        "def _demojize_bracketed(text: str) -> str:\n",
        "    \"\"\"Replace each emoji with italian_name] to preserve irony signal for Claude.\"\"\"\n",
        "    def _replace(m):\n",
        "        em = m.group()\n",
        "        alias = emoji.demojize(em, language=\"it\")\n",
        "        if alias == em:  # fallback: library returned the char unchanged\n",
        "            alias = emoji.demojize(em, language=\"en\")\n",
        "        alias = alias.strip(\":\").replace(\"_\", \" \")\n",
        "        return f\" {alias} \"\n",
        "    return _EMOJI_RE.sub(_replace, text)\n",
        "\n",
        "def preprocess_for_claude(text: str) -> str:\n",
        "    \"\"\"Keep emoji as name] brackets, then apply shared cleaning. Fed to Claude only.\"\"\"\n",
        "    if not isinstance(text, str) or not text.strip():\n",
        "        return \"\"\n",
        "    text = _demojize_bracketed(text)\n",
        "    return _base_clean(text)\n",
        "\n",
        "\n",
        "# ── Smoke test ───────────────────────────────────────────────────────────────\n",
        "_test = \"Ma certo, geniale come al solito 🙄👏 #italia @utente https://t.co/xxx\"\n",
        "print(f\"Input:         {_test}\")\n",
        "print(f\"→ BERT path:   {preprocess_for_bert(_test)}\")\n",
        "print(f\"→ Claude path: {preprocess_for_claude(_test)}\")\n",
        "print(\"✅ Preprocessing OK\")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "md-6",
      "metadata": {
        "id": "md-6"
      },
      "source": [
        "## 🧠 Cell 6 — Embedding model\n",
        "Loads `paraphrase-multilingual-mpnet-base-v2` (~420 MB). May take 1–2 min on first run."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cell-6",
      "metadata": {
        "id": "cell-6"
      },
      "outputs": [],
      "source": [
        "class ItalianEmbedder:\n",
        "    \"\"\"768-dim multilingual sentence embeddings optimised for Italian social media.\"\"\"\n",
        "\n",
        "    def __init__(self, model_name=EMBEDDING_MODEL, batch_size=EMBEDDING_BATCH_SIZE):\n",
        "        self.batch_size = batch_size\n",
        "        print(f\"[Embedder] Loading {model_name} …\")\n",
        "        self.model = SentenceTransformer(model_name, device=device)\n",
        "        print(f\"[Embedder] Ready on {device.upper()}  |  dim=768\")\n",
        "\n",
        "    def encode(self, texts: list[str], normalize: bool = True,\n",
        "               show_progress: bool = True) -> np.ndarray:\n",
        "        if not texts:\n",
        "            return np.empty((0, 768), dtype=np.float32)\n",
        "        vecs = self.model.encode(\n",
        "            texts,\n",
        "            batch_size=self.batch_size,\n",
        "            normalize_embeddings=normalize,\n",
        "            show_progress_bar=show_progress,\n",
        "            convert_to_numpy=True,\n",
        "        )\n",
        "        return vecs.astype(np.float32)\n",
        "\n",
        "    def top_similar(\n",
        "        self,\n",
        "        query: str,\n",
        "        corpus_vectors: np.ndarray,\n",
        "        corpus_texts: list[str],\n",
        "        top_k: int = 5,\n",
        "    ) -> list[tuple[float, int, str]]:\n",
        "        \"\"\"Returns (score, original_index, text) so callers can safely look up df.iloc[idx].\"\"\"\n",
        "        q_vec = self.encode([preprocess_for_bert(query)], show_progress=False)[0]\n",
        "        scores = corpus_vectors @ q_vec\n",
        "        top_idx = np.argsort(scores)[::-1][:top_k]\n",
        "        return [(float(scores[i]), int(i), corpus_texts[i]) for i in top_idx]\n",
        "\n",
        "\n",
        "embedder = ItalianEmbedder()"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "md-7",
      "metadata": {
        "id": "md-7"
      },
      "source": [
        "## 💬 Cell 7 — Sentiment analyser (two-layer)\n",
        "Layer A: Italian BERT (local, fast, receives emoji-stripped text). Layer B: Claude via Vertex AI (sarcasm correction, called selectively, receives `[emoji:name]` formatted text + optional parent comment for context)."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cell-7",
      "metadata": {
        "id": "cell-7"
      },
      "outputs": [],
      "source": [
        "# ── Prompt template ────────────────────────────────────────────────────────\n",
        "# {parent_block} is either empty or a CONTESTO section injected at call time.\n",
        "SARCASM_PROMPT = \"\"\"Sei un esperto di linguistica e analisi del sentiment sui social media italiani.\n",
        "Analizza questo commento/post sui social media:\n",
        "\n",
        "TESTO: \"{text}\"\n",
        "{parent_block}\n",
        "Il sentiment iniziale rilevato automaticamente è: {base_sentiment} (confidenza: {confidence:.0%})\n",
        "\n",
        "Il tuo compito:\n",
        "1. Determina se c'è sarcasmo, ironia o umorismo che inverte il sentiment reale.\n",
        "2. Considera gli emoji nel formato [emoji:nome] — la loro presenza o assenza rispetto al tono\n",
        "   del testo è spesso il segnale chiave del sarcasmo.\n",
        "3. Fornisci il sentiment REALE del testo.\n",
        "\n",
        "Rispondi SOLO con questo JSON (nessun testo aggiuntivo):\n",
        "{{\n",
        "  \"is_sarcastic\": true/false,\n",
        "  \"real_sentiment\": \"positive\" | \"neutral\" | \"negative\",\n",
        "  \"confidence\": 0.0-1.0,\n",
        "  \"reason\": \"breve spiegazione in italiano (max 15 parole)\"\n",
        "}}\"\"\"\n",
        "\n",
        "\n",
        "@dataclass\n",
        "class SentimentResult:\n",
        "    text: str              # original raw text\n",
        "    processed_bert: str    # emoji-stripped, fed to BERT\n",
        "    processed_claude: str  # [emoji:name] format, fed to Claude\n",
        "    base_sentiment: str = \"\"\n",
        "    base_confidence: float = 0.0\n",
        "    is_sarcastic: bool = False\n",
        "    final_sentiment: str = \"\"\n",
        "    final_confidence: float = 0.0\n",
        "    sarcasm_reason: str = \"\"\n",
        "    gemini_called: bool = False # Renamed from claude_called\n",
        "\n",
        "    def to_dict(self):\n",
        "        return {\n",
        "            \"text\":             self.text,\n",
        "            \"base_sentiment\":   self.base_sentiment,\n",
        "            \"base_confidence\":  round(self.base_confidence, 4),\n",
        "            \"is_sarcastic\":     self.is_sarcastic,\n",
        "            \"final_sentiment\":  self.final_sentiment,\n",
        "            \"final_confidence\": round(self.final_confidence, 4),\n",
        "            \"sarcasm_reason\":   self.sarcasm_reason,\n",
        "            \"gemini_called\":    self.gemini_called, # Renamed\n",
        "        }\n",
        "\n",
        "\n",
        "class ItalianSentimentAnalyser:\n",
        "    \"\"\"Two-layer sarcasm-aware Italian sentiment analyser using Gemini on Vertex AI.\"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        print(f\"[Sentiment] Loading {SENTIMENT_MODEL} …\")\n",
        "        self._clf = hf_pipeline(\n",
        "            \"text-classification\",\n",
        "            model=SENTIMENT_MODEL,\n",
        "            truncation=True,\n",
        "            max_length=512,\n",
        "            device=0 if device == \"cuda\" else -1,\n",
        "        )\n",
        "        self._gemini = gemini_client  # Gemini client from Cell 2\n",
        "        self._kw_re = re.compile(\n",
        "            r\"\\b(\" + \"|\".join(re.escape(k) for k in SARCASM_KEYWORDS_IT) + r\")\\b\",\n",
        "            re.IGNORECASE,\n",
        "        )\n",
        "        print(\"[Sentiment] Ready (Vertex AI Gemini layer active).\")\n",
        "\n",
        "    # ── Layer A: BERT ────────────────────────────────────────────────────────\n",
        "    def _base(self, bert_texts: list[str]) -> list[tuple[str, float]]:\n",
        "        \"\"\"Run BERT on emoji-stripped texts in batches for GPU efficiency.\"\"\"\n",
        "        out = []\n",
        "        for i in range(0, len(bert_texts), SENTIMENT_BATCH_SIZE):\n",
        "            for p in self._clf(bert_texts[i : i + SENTIMENT_BATCH_SIZE]):\n",
        "                out.append((SENTIMENT_LABELS.get(p[\"label\"], p[\"label\"]), float(p[\"score\"])))\n",
        "        return out\n",
        "\n",
        "    # ── Gate: should we check with Gemini? ──────────────────────────────────\n",
        "    def _needs_check(self, claude_text: str, conf: float) -> bool:\n",
        "        \"\"\"Check against the [emoji:name] formatted text — keywords and low confidence.\"\"\"\n",
        "        return conf < SARCASM_CONFIDENCE_THRESHOLD or bool(self._kw_re.search(claude_text))\n",
        "\n",
        "    # ── Layer B: Gemini sarcasm detection ───────────────────────────────────\n",
        "    def _detect_sarcasm(\n",
        "        self,\n",
        "        claude_text: str,\n",
        "        base_sent: str,\n",
        "        conf: float,\n",
        "        parent_text: str | None = None,\n",
        "    ) -> tuple[bool, str, float, str]:\n",
        "        \"\"\"\n",
        "        Returns (is_sarcastic, real_sentiment, confidence, reason).\n",
        "        claude_text: [emoji:name] formatted text.\n",
        "        parent_text: optional raw text of the parent comment for conversational context.\n",
        "        \"\"\"\n",
        "        if parent_text:\n",
        "            parent_block = (\n",
        "                f\"CONTESTO (commento a cui risponde): \\\"{preprocess_for_claude(parent_text)}\\\"\\n\"\n",
        "            )\n",
        "        else:\n",
        "            parent_block = \"\"\n",
        "\n",
        "        prompt = SARCASM_PROMPT.format(\n",
        "            text=claude_text,\n",
        "            parent_block=parent_block,\n",
        "            base_sentiment=base_sent,\n",
        "            confidence=conf,\n",
        "        )\n",
        "        try:\n",
        "            # Gemini API call\n",
        "            response = self._gemini.generate_content(\n",
        "                [Part.from_text(prompt)],\n",
        "                generation_config=vertexai.preview.generative_models.GenerationConfig(\n",
        "                    max_output_tokens=GEMINI_MAX_TOKENS, temperature=0.2, top_p=0.9, top_k=20\n",
        "                ),\n",
        "                system_instruction=[\n",
        "                     \"Sei un esperto di NLP specializzato nell'analisi del sentiment \"\n",
        "                     \"e del sarcasmo in italiano sui social media. \"\n",
        "                     \"Rispondi SEMPRE e SOLO in formato JSON valido.\"\n",
        "                ]\n",
        "            )\n",
        "            raw = response.candidates[0].content.parts[0].text.strip()\n",
        "            d = json.loads(raw)\n",
        "            return (\n",
        "                bool(d.get(\"is_sarcastic\", False)),\n",
        "                str(d.get(\"real_sentiment\", base_sent)),\n",
        "                float(d.get(\"confidence\", conf)),\n",
        "                str(d.get(\"reason\", \"\")),\n",
        "            )\n",
        "        except Exception as e:\n",
        "            return False, base_sent, conf, f\"[err: {e}]\"\n",
        "\n",
        "    # ── Main entry point ────────────────────────────────────────────────────\n",
        "    def analyse(\n",
        "        self,\n",
        "        raw_texts: list[str],\n",
        "        parent_texts: list[str | None] | None = None,\n",
        "        show_progress: bool = True,\n",
        "    ) -> list[SentimentResult]:\n",
        "        \"\"\"\n",
        "        Args:\n",
        "            raw_texts:    Original untouched texts (one per comment).\n",
        "            parent_texts: Optional list of parent comment texts, same length as raw_texts.\n",
        "                          Pass None or an empty list to skip parent context entirely.\n",
        "                          Individual entries may be None for root comments.\n",
        "        \"\"\"\n",
        "        n = len(raw_texts)\n",
        "        if parent_texts is None:\n",
        "            parent_texts = [None] * n\n",
        "        assert len(parent_texts) == n, \"parent_texts must be same length as raw_texts\"\n",
        "\n",
        "        # Preprocess each text for both paths upfront\n",
        "        bert_texts   = [preprocess_for_bert(t)   for t in raw_texts]\n",
        "        claude_texts = [preprocess_for_claude(t)  for t in raw_texts]\n",
        "\n",
        "        print(\"[Sentiment] Running Italian BERT …\")\n",
        "        base_results = self._base(bert_texts)\n",
        "\n",
        "        results, n_gemini = [], 0 # Renamed n_claude to n_gemini\n",
        "        iterator = zip(raw_texts, bert_texts, claude_texts, parent_texts, base_results)\n",
        "        if show_progress:\n",
        "            iterator = tqdm(iterator, total=n, desc=\"Sarcasm check\")\n",
        "\n",
        "        for raw, bert_t, claude_t, parent_t, (bl, bc) in iterator:\n",
        "            r = SentimentResult(\n",
        "                text=raw, processed_bert=bert_t, processed_claude=claude_t,\n",
        "                base_sentiment=bl, base_confidence=bc,\n",
        "            )\n",
        "            if self._needs_check(claude_t, bc):\n",
        "                r.is_sarcastic, r.final_sentiment, r.final_confidence, r.sarcasm_reason = (\n",
        "                    self._detect_sarcasm(claude_t, bl, bc, parent_text=parent_t)\n",
        "                )\n",
        "                r.gemini_called = True # Renamed claude_called to gemini_called\n",
        "                n_gemini += 1\n",
        "            else:\n",
        "                r.final_sentiment, r.final_confidence = bl, bc\n",
        "            results.append(r)\n",
        "\n",
        "        pct = 100 * n_gemini / max(n, 1)\n",
        "        print(f\"[Sentiment] Done. Gemini called for {n_gemini}/{n} posts ({pct:.1f}%)\") # Updated print message\n",
        "        return results\n",
        "\n",
        "sentiment_analyser = ItalianSentimentAnalyser()"
      ]
    },
