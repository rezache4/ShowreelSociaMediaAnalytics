      "source": [
        "## 📥 Cell 9 — Load data from GCS\n",
        "\n",
        "Loads `ig_comments_cleaned.parquet` from GCS, samples `SAMPLE_N` rows, then builds:\n",
        "- `RAW_POSTS` — list of raw comment texts (pipeline input)\n",
        "- `PARENT_MAP` — dict mapping `comment_id → parent comment text` for comments whose parent exists in the sample (used by Claude for conversational context)\n",
        "- `ig_comments` — full sampled DataFrame (used by the thread viewer in Cell 20)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cell-9",
      "metadata": {
        "id": "cell-9"
      },
      "outputs": [],
      "source": [
        "# ── Load from GCS ───────────────────────────────────────────────────────────\n",
        "gcs_client = storage.Client(project=GCS_PROJECT)  # separate from vertex_client\n",
        "parquet_uri = f\"gs://{GCS_BUCKET}/{PARQUET_PATH}\"\n",
        "print(f\"Reading {parquet_uri} …\")\n",
        "ig_comments = pd.read_parquet(parquet_uri)\n",
        "print(f\"Loaded {len(ig_comments):,} rows  |  columns: {ig_comments.columns.tolist()}\")\n",
        "\n",
        "# ── Sample for speed ────────────────────────────────────────────────────────\n",
        "if SAMPLE_N and len(ig_comments) > SAMPLE_N:\n",
        "    ig_comments = ig_comments.sample(n=SAMPLE_N, random_state=SAMPLE_SEED).reset_index(drop=True)\n",
        "    print(f\"Sampled {SAMPLE_N} comments (seed={SAMPLE_SEED})\")\n",
        "\n",
        "# ── Validate required columns ────────────────────────────────────────────────\n",
        "required_cols = {\"comment_id\", \"text\", \"parent_id\"}\n",
        "missing = required_cols - set(ig_comments.columns)\n",
        "if missing:\n",
        "    raise ValueError(f\"Dataset is missing required columns: {missing}\")\n",
        "\n",
        "# ── Build pipeline inputs ────────────────────────────────────────────────────\n",
        "# RAW_POSTS: plain list of comment texts, preserving row order\n",
        "ig_comments[\"text\"] = ig_comments[\"text\"].fillna(\"\").astype(str)\n",
        "RAW_POSTS = ig_comments[\"text\"].tolist()\n",
        "\n",
        "# PARENT_MAP: comment_id → parent text, only for parents present in this sample\n",
        "id_to_text = dict(zip(ig_comments[\"comment_id\"], ig_comments[\"text\"]))\n",
        "PARENT_MAP: dict[str, str | None] = {}\n",
        "for _, row in ig_comments.iterrows():\n",
        "    pid = row.get(\"parent_id\")\n",
        "    if pd.notna(pid) and pid in id_to_text:\n",
        "        PARENT_MAP[row[\"comment_id\"]] = id_to_text[pid]\n",
        "    else:\n",
        "        PARENT_MAP[row[\"comment_id\"]] = None\n",
        "\n",
        "# Ordered list aligned with RAW_POSTS\n",
        "PARENT_TEXTS = [\n",
        "    PARENT_MAP.get(str(cid)) for cid in ig_comments[\"comment_id\"]\n",
        "]\n",
        "\n",
        "n_with_parent = sum(1 for p in PARENT_TEXTS if p is not None)\n",
        "print(f\"\\n{'='*50}\")\n",
        "print(f\"  Pipeline inputs ready\")\n",
        "print(f\"{'='*50}\")\n",
        "print(f\"  Total comments : {len(RAW_POSTS):,}\")\n",
        "print(f\"  With parent ctx: {n_with_parent:,} ({100*n_with_parent/len(RAW_POSTS):.1f}%)\")\n",
        "print(f\"{'='*50}\")\n",
        "ig_comments.head(3)"
      ]
    },
