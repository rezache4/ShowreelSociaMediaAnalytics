      "cell_type": "markdown",
      "id": "md-8",
      "metadata": {
        "id": "md-8"
      },
      "source": [
        "## 🗂️ Cell 8 — Topic clustering (UMAP + HDBSCAN)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "cell-8",
      "metadata": {
        "id": "cell-8"
      },
      "outputs": [],
      "source": [
        "class TopicClusterer:\n",
        "    \"\"\"UMAP dimensionality reduction + HDBSCAN clustering + Gemini auto-labelling.\"\"\"\n",
        "\n",
        "    def __init__(self):\n",
        "        self._umap_full = umap.UMAP(\n",
        "            n_neighbors=UMAP_N_NEIGHBORS, min_dist=UMAP_MIN_DIST,\n",
        "            n_components=UMAP_N_COMPONENTS, metric=\"cosine\", random_state=42,\n",
        "        )\n",
        "        self._umap_2d = umap.UMAP(\n",
        "            n_neighbors=UMAP_N_NEIGHBORS, min_dist=0.05,\n",
        "            n_components=2, metric=\"cosine\", random_state=42,\n",
        "        )\n",
        "        self._hdbscan = hdbscan.HDBSCAN(\n",
        "            min_cluster_size=HDBSCAN_MIN_CLUSTER_SIZE,\n",
        "            min_samples=HDBSCAN_MIN_SAMPLES,\n",
        "            metric=\"euclidean\", cluster_selection_method=\"eom\",\n",
        "        )\n",
        "        self._gemini = gemini_client  # same Gemini client as the sentiment analyser\n",
        "\n",
        "    def fit(self, embeddings: np.ndarray) -> tuple[np.ndarray, np.ndarray]:\n",
        "        \"\"\"Returns (cluster_labels, reduced_2d) where -1 = noise.\"\"\"\n",
        "        print(\"[Cluster] UMAP 768→5D …\")\n",
        "        reduced_5d = self._umap_full.fit_transform(embeddings)\n",
        "        print(\"[Cluster] UMAP 768→2D (for visualization) …\")\n",
        "        reduced_2d = self._umap_2d.fit_transform(embeddings)\n",
        "        print(\"[Cluster] HDBSCAN …\")\n",
        "        labels = self._hdbscan.fit_predict(reduced_5d)\n",
        "        n_c     = len(set(labels)) - (1 if -1 in labels else 0)\n",
        "        n_noise = (labels == -1).sum()\n",
        "        print(f\"[Cluster] {n_c} clusters found | {n_noise} noise points ({100*n_noise/len(labels):.1f}%)\")\n",
        "        return labels, reduced_2d\n",
        "\n",
        "    def cluster_summary(\n",
        "        self, labels: np.ndarray, raw_texts: list[str], top_k: int = 5\n",
        "    ) -> dict:\n",
        "        \"\"\"Build summary dict from original (non-preprocessed) texts for readability.\"\"\"\n",
        "        summary = {}\n",
        "        for cid in sorted(set(labels)):\n",
        "            if cid == -1:\n",
        "                continue\n",
        "            mask = labels == cid\n",
        "            summary[cid] = {\n",
        "                \"size\": int(mask.sum()),\n",
        "                \"representative_posts\": [t for t, m in zip(raw_texts, mask) if m][:top_k],\n",
        "                \"label\": None,\n",
        "                \"description\": \"\",\n",
        "            }\n",
        "        return summary\n",
        "\n",
        "    def auto_label_clusters(self, summary: dict, context: str = \"\") -> dict:\n",
        "        print(f\"[Cluster] Auto-labelling {len(summary)} clusters with Gemini …\")\n",
        "        for cid, info in summary.items():\n",
        "            posts = \"\\n\".join(f\"- {p}\" for p in info[\"representative_posts\"])\n",
        "            prompt = (\n",
        "                \"Sei un analista di social media italiano.\\n\"\n",
        "                + (f\"Contesto influencer: {context}\\n\" if context else \"\")\n",
        "                + f\"\\nPost del cluster {cid}:\\n{posts}\\n\\n\"\n",
        "                \"Fornisci etichetta (max 5 parole) e descrizione (1 frase).\\n\"\n",
        "                'Rispondi SOLO in JSON: {\"label\": \"...\", \"description\": \"...\"}'\n",
        "            )\n",
        "            try:\n",
        "                # Gemini API call for auto-labelling\n",
        "                response = self._gemini.generate_content(\n",
        "                    [Part.from_text(prompt)],\n",
        "                    generation_config=vertexai.preview.generative_models.GenerationConfig(\n",
        "                        max_output_tokens=GEMINI_MAX_TOKENS, temperature=0.2, top_p=0.9, top_k=20\n",
        "                    ),\n",
        "                    system_instruction=[\n",
        "                         \"Sei un esperto di NLP specializzato nell'analisi dei cluster \"\n",
        "                         \"e nel riassunto di argomenti in italiano sui social media. \"\n",
        "                         \"Rispondi SEMPRE e SOLO in formato JSON valido.\"\n",
        "                    ]\n",
        "                )\n",
        "                raw = response.candidates[0].content.parts[0].text.strip()\n",
        "                d = json.loads(raw)\n",
        "                info[\"label\"]       = d.get(\"label\", f\"Cluster {cid}\")\n",
        "                info[\"description\"] = d.get(\"description\", \"\")\n",
        "            except Exception as e:\n",
        "                info[\"label\"]       = f\"Cluster {cid}\"\n",
        "                info[\"description\"] = str(e)\n",
        "        return summary\n",
        "\n",
        "\n",
        "clusterer = TopicClusterer()\n",
        "print(\"✅ Clusterer ready.\")"
      ]
    },
