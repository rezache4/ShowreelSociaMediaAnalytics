        "# ── 2. Per-media summary ──────────────────────────────────────────────────────\n",
        "media_summary = (\n",
        "    thread_df.groupby(\"media_id\")\n",
        "    .agg(\n",
        "        total_comments     = (\"idx\", \"count\"),\n",
        "        n_replies          = (\"is_reply\", \"sum\"),\n",
        "        n_sarcastic        = (\"is_sarcastic\", \"sum\"),\n",
        "        pct_positive       = (\"final_sentiment\", lambda x: (x == \"positive\").mean() * 100),\n",
        "        pct_negative       = (\"final_sentiment\", lambda x: (x == \"negative\").mean() * 100),\n",
        "        pct_neutral        = (\"final_sentiment\", lambda x: (x == \"neutral\").mean() * 100),\n",
        "        mean_confidence    = (\"final_confidence\", \"mean\"),\n",
        "    )\n",
        "    .reset_index()\n",
        ")\n",
        "media_summary[\"pct_sarcastic\"] = (\n",
        "    media_summary[\"n_sarcastic\"] / media_summary[\"total_comments\"] * 100\n",
        ").round(1)\n",
        "media_summary = media_summary.sort_values(\"total_comments\", ascending=False)\n",
        "\n",
        "print(f\"{'='*55}\")\n",
        "print(f\"  THREAD SUMMARY — {len(media_summary)} media posts\")\n",
        "print(f\"{'='*55}\")\n",
        "print(f\"  Total comments analysed: {thread_df.shape[0]:,}\")\n",
        "print(f\"  Root comments:           {(~thread_df['is_reply']).sum():,}\")\n",
        "print(f\"  Replies:                 {thread_df['is_reply'].sum():,}\")\n",
        "print(f\"{'='*55}\")\n",
        "\n",
        "# ── 3. Visualise: top 20 posts by comment volume ──────────────────────────────\n",
        "top20 = media_summary.head(20).copy()\n",
        "\n",
        "fig = go.Figure()\n",
        "for sentiment, color in [(\"pct_positive\", \"#1D9E75\"), (\"pct_neutral\", \"#888780\"), (\"pct_negative\", \"#D85A30\")]:\n",
        "    label = sentiment.replace(\"pct_\", \"\").capitalize()\n",
        "    fig.add_trace(go.Bar(\n",
        "        name=label,\n",
        "        x=top20[\"media_id\"].astype(str),\n",
        "        y=top20[sentiment].round(1),\n",
        "        marker_color=color,\n",
        "        hovertemplate=f\"{label}: %{{y:.1f}}%<br>Post: %{{x}}<extra></extra>\",\n",
        "    ))\n",
        "fig.update_layout(\n",
        "    barmode=\"stack\",\n",
        "    title=\"Sentiment distribution per media post (top 20 by comment volume)\",\n",
        "    xaxis_title=\"media_id\",\n",
        "    yaxis_title=\"% of comments\",\n",
        "    height=450,\n",
        "    xaxis_tickangle=-45,\n",
        "    plot_bgcolor=\"white\", paper_bgcolor=\"white\",\n",
        "    legend=dict(orientation=\"h\", yanchor=\"bottom\", y=1.02, xanchor=\"right\", x=1),\n",
        "    font=dict(family=\"Arial\", size=12),\n",
        ")\n",
        "fig.update_yaxes(gridcolor=\"#eee\", range=[0, 105])\n",
        "fig.show()\n",
        "\n",
        "# ── 4. Sarcasm rate per post ──────────────────────────────────────────────────\n",
        "top_sarc = media_summary.nlargest(15, \"pct_sarcastic\")\n",
        "fig2 = go.Figure(go.Bar(\n",
        "    x=top_sarc[\"media_id\"].astype(str),\n",
        "    y=top_sarc[\"pct_sarcastic\"],\n",
        "    marker_color=\"#EF9F27\",\n",
        "    text=top_sarc[\"pct_sarcastic\"].astype(str) + \"%\",\n",
        "    textposition=\"outside\",\n",
        "))\n",
        "fig2.update_layout(\n",
        "    title=\"Sarcasm rate per media post (top 15)\",\n",
        "    xaxis_title=\"media_id\", yaxis_title=\"% sarcastic comments\",\n",
        "    xaxis_tickangle=-45, height=400,\n",
        "    plot_bgcolor=\"white\", yaxis=dict(gridcolor=\"#eee\"),\n",
        "    font=dict(family=\"Arial\", size=12),\n",
        ")\n",
        "fig2.show()\n",
        "\n",
        "# ── 5. Print most-discussed posts with worst sentiment ────────────────────────\n",
        "print(\"\\nTop 5 posts by negative sentiment rate (min 10 comments):\")\n",
        "worst = media_summary[media_summary[\"total_comments\"] >= 10].nlargest(5, \"pct_negative\")\n",
        "for _, row in worst.iterrows():\n",
        "    print(\n",
        "        f\"  media_id={row['media_id']} | \"\n",
        "        f\"{row['total_comments']} comments | \"\n",
        "        f\"{row['pct_negative']:.1f}% negative | \"\n",
        "        f\"{row['pct_sarcastic']:.1f}% sarcastic\"\n",
        "    )\n",
        "\n",
        "media_summary.head(10)"
      ]
